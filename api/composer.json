{
  "type": "project",
  "license": "proprietary",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": "^8.3",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "comgate/sdk": "^1.9.2",
    "doctrine/dbal": "^3.10.5",
    "doctrine/doctrine-bundle": "^2.18.2",
    "doctrine/doctrine-migrations-bundle": "^3.7.0",
    "doctrine/orm": "^3.6.5",
    "dompdf/dompdf": "^3.1.5",
    "kreait/firebase-php": "^7.24.1",
    "lexik/jwt-authentication-bundle": "^3.2.0",
    "nelmio/api-doc-bundle": "^5.10.2",
    "nelmio/cors-bundle": "^2.6.1",
    "phpoffice/phpspreadsheet": "^5.7",
    "symfony/asset": "^7.4.8",
    "symfony/console": "^7.4.11",
    "symfony/dotenv": "^7.4.11",
    "symfony/flex": "^2.10",
    "symfony/framework-bundle": "^7.4.11",
    "symfony/http-client": "^7.4.9",
    "symfony/http-foundation": "^7.4.8",
    "symfony/intl": "^7.4.8",
    "symfony/mailer": "^7.4.8",
    "symfony/monolog-bundle": "^3.11.2",
    "symfony/runtime": "^7.4.8",
    "symfony/serializer": "^7.4.10",
    "symfony/twig-bundle": "^7.4.8",
    "symfony/validator": "^7.4.10",
    "symfony/yaml": "^7.4.11",
    "twig/extra-bundle": "^3.24"
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true,
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "bump-after-update": true,
    "sort-packages": true,
    "platform": {
      "php": "8.3"
    }
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "replace": {
    "symfony/polyfill-ctype": "*",
    "symfony/polyfill-iconv": "*",
    "symfony/polyfill-php72": "*",
    "symfony/polyfill-php73": "*",
    "symfony/polyfill-php74": "*",
    "symfony/polyfill-php80": "*",
    "symfony/polyfill-php81": "*",
    "symfony/polyfill-php82": "*"
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "^7.3.7",
      "docker": true
    }
  },
  "require-dev": {
    "phpstan/phpstan": ">=2.1.54",
    "phpstan/phpstan-doctrine": ">=2.0.22",
    "phpstan/phpstan-symfony": ">=2.0.17",
    "phpunit/phpunit": "^12.5.25",
    "symfony/maker-bundle": "^1.67.0"
  }
}
